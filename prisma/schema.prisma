generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // This is the URL the Prisma Client will use for queries (Pooler/Port5432 or 6543)
  url       = env("DATABASE_URL") 
  
  // This is the URL the Prisma CLI will use for migrations (Direct Connection/Port 5432)
  directUrl = env("DIRECT_URL")
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  password         String?
  role             Role
  createdAt        DateTime           @default(now())
  firstName        String
  lastName         String
  phone            String
  iban             String?
  bic              String?
  bankName         String?
  students         Student[]
  NotificationRead NotificationRead[]
  inviteToken      String?            @unique
  teacher          Teacher?
  civility         String?
  tenantId         String?
  tenant           Tenant?            @relation(fields: [tenantId], references: [id])
  address          String?
  Staff            Staff[]
}

model Student {
  id              String         @id @default(cuid())
  firstName       String
  lastName        String
  birthDate       DateTime
  address         String
  hasHealthIssues Boolean
  healthDetails   String?
  canLeaveAlone   Boolean
  status          String         @default("PENDING")
  parentId        String
  parent          User           @relation(fields: [parentId], references: [id])
  classId         String?
  class           Class?         @relation(fields: [classId], references: [id])
  createdAt       DateTime       @default(now())
  notifications   Notification[]
  documents       Document[]
  code            String?        @unique @default(uuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
}

model Class {
  id           String     @id @default(cuid())
  name         String
  monthlyFee   Float
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])
  schoolYearId String
  createdAt    DateTime   @default(now())
  subjects     Subject[]
  teachers     Teacher[]
  Student      Student[]
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
}

model Document {
  id        String   @id @default(cuid())
  url       String
  fileName  String
  fileType  String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
  studentId String
}

model Subject {
  id        String    @id @default(cuid())
  name      String
  class     Class     @relation(fields: [classId], references: [id])
  classId   String
  createdAt DateTime  @default(now())
  teachers  Teacher[]
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
}

model Teacher {
  id                String                    @id @default(cuid())
  userId            String?                   @unique
  user              User?                     @relation(fields: [userId], references: [id])
  subject           Subject?                  @relation(fields: [subjectId], references: [id])
  subjectId         String?
  class             Class?                    @relation(fields: [classId], references: [id])
  classId           String?
  Notification      Notification[]
  notificationsRead NotificationReadTeacher[]
  tenantId          String
  tenant            Tenant                    @relation(fields: [tenantId], references: [id])
}

model SchoolYear {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())

  classes  Class[]
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
}

model Notification {
  id             String                    @id @default(cuid())
  title          String
  message        String
  isGlobal       Boolean
  studentId      String?
  student        Student?                  @relation(fields: [studentId], references: [id])
  teacherId      String?
  teacher        Teacher?                  @relation(fields: [teacherId], references: [id])
  tenantId       String?
  tenant         Tenant?                   @relation(fields: [tenantId], references: [id]) // ← RELATION
  createdAt      DateTime                  @default(now())
  readBy         NotificationRead[]
  readByTeachers NotificationReadTeacher[]
}

model NotificationRead {
  id             String       @id @default(uuid())
  notification   Notification @relation(fields: [notificationId], references: [id])
  notificationId String
  parent         User         @relation(fields: [parentId], references: [id])
  parentId       String
  readAt         DateTime?

  @@unique([notificationId, parentId])
}

model NotificationReadTeacher {
  id             String       @id @default(uuid())
  notification   Notification @relation(fields: [notificationId], references: [id])
  notificationId String
  teacher        Teacher      @relation(fields: [teacherId], references: [id])
  teacherId      String
  readAt         DateTime?

  @@unique([notificationId, teacherId])
}

model Tenant {
  id                   String                  @id @default(cuid())
  name                 String
  email                String?
  uniqueNumber         Int?                    @unique // ex: 123456
  stripeCustomerId     String?
  billingPlan          BillingPlan             @default(FREE_TRIAL)
  trialEndsAt          DateTime?
  createdAt            DateTime                @default(now())
  status               String?
  users                User[]
  students             Student[]
  classes              Class[]
  teachers             Teacher[]
  subjects             Subject[]
  years                SchoolYear[]
  phone                String?
  siret                String?
  address              String?
  postal               String?
  city                 String?
  country              String?
  landlinePhone        String?
  Notification         Notification[]
  schoolCode           String                  @unique
  InvitedParent        InvitedParent[]
  subscriptionStatus   String? // ex: "ACTIVE", "TRIAL", "EXPIRED"
  stripeSubscriptionId String?
  staff                Staff[]
  preRegistrations     PreRegistrationParent[]
  tenantApplication TenantApplication?
}

model TenantApplication {
  id              String                  @id @default(cuid())
  name            String                  // School Name
  firstName       String                  // Applicant's First Name (Director)
  lastName        String                  // Applicant's Last Name (Director)
  email           String                  // Contact Email (Should not be @unique here!)
  phone           String?
  siret           String?
  address         String?
  postal          String?
  city            String?
  country         String?
  landlinePhone   String?
  requestedBy     String?                 // Optional: ID of the requesting User
  validatedAt     DateTime?
  status          PreRegistrationStatus   @default(PENDING)
  rejectionReason String?                 // Reason for rejection
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  approvedById    String?                 // ID of the User who approved/rejected the request
  
  // Only the TENANT LINK is UNIQUE, as a Tenant can only come from one approved application.
  tenantId        String?                 @unique 
  tenant          Tenant?                 @relation(fields: [tenantId], references: [id])
}

model InvitedParent {
  id        String   @id @default(cuid())
  email     String
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  firstName String?
}

model Staff {
  id          String    @id @default(cuid())
  email       String    @unique
  firstName   String
  lastName    String
  phone       String
  roleLabel   String // ex: "Secrétaire", "Assistant administratif"
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  validatedAt DateTime?
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  schoolCode  String?
  accepted    Boolean   @default(false)
  user        User?     @relation(fields: [userId], references: [id])
  userId      String?

  @@unique([email, tenantId])
}

model PreRegistrationParent {
  id        String                   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String
  address   String
  createdAt DateTime                 @default(now())
  status    PreRegistrationStatus    @default(PENDING)
  tenantId  String
  tenant    Tenant                   @relation(fields: [tenantId], references: [id])
  children  PreRegistrationChild[]
  documents PreRegistrationDocument?
}

model PreRegistrationDocument {
  id                  String                @id @default(cuid())
  motivationLetterUrl String?
  schoolResultsUrl    String?
  familyBookUrl       String?
  parentId            String                @unique
  parent              PreRegistrationParent @relation(fields: [parentId], references: [id])
}

model PreRegistrationChild {
  id            String                @id @default(cuid())
  firstName     String
  lastName      String
  gender        String
  birthDate     DateTime
  birthCity     String
  birthCountry  String
  currentSchool String
  desiredClass  String
  status        PreRegistrationStatus @default(PENDING)
  parent        PreRegistrationParent @relation(fields: [parentId], references: [id])
  parentId      String
  createdAt     DateTime              @default(now())
}

enum Gender {
  FILLE
  GARÇON
}

enum BillingPlan {
  FREE_TRIAL
  MONTHLY
  YEARLY
}

enum Role {
  PARENT
  TEACHER
  DIRECTOR
  SUPER_ADMIN
  STAFF
}

enum Civility {
  M
  Mme
  Mlle
}

enum PreRegistrationStatus {
  PENDING
  ACCEPTED
  REJECTED
}
