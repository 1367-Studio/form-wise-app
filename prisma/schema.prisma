generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // This is the URL the Prisma Client will use for queries (Pooler/Port5432 or 6543)
  url       = env("DATABASE_URL") 
  
  // This is the URL the Prisma CLI will use for migrations (Direct Connection/Port 5432)
  directUrl = env("DIRECT_URL")
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  password         String?
  role             Role
  createdAt        DateTime           @default(now())
  tokenVersion     Int                @default(1)
  firstName        String
  lastName         String
  phone            String
  iban             String?
  bic              String?
  bankName         String?
  students         Student[]
  NotificationRead NotificationRead[]
  inviteToken      String?            @unique
  teacher          Teacher?
  civility         String?
  tenantId         String?
  tenant           Tenant?            @relation(fields: [tenantId], references: [id])
  address          String?
  Staff            Staff[]
  createdPickupAuthorizations PickupAuthorization[] @relation("PickupAuthorizationCreatedBy")
  loggedPickupEvents          PickupEvent[]         @relation("PickupEventLoggedBy")
  pushSubscriptions           PushSubscription[]
  conversationParticipants    ConversationParticipant[]
  sentMessages                Message[]
}

model Student {
  id              String         @id @default(cuid())
  firstName       String
  lastName        String
  birthDate       DateTime
  address         String
  hasHealthIssues Boolean
  healthDetails   String?
  canLeaveAlone   Boolean
  status          String         @default("PENDING")
  parentId        String
  parent          User           @relation(fields: [parentId], references: [id])
  classId         String?
  class           Class?         @relation(fields: [classId], references: [id])
  createdAt       DateTime       @default(now())
  notifications   Notification[]
  documents       Document[]
  attendance      Attendance[]
  code            String?        @unique @default(uuid())
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  pickupAuthorizations PickupAuthorization[]
  pickupEvents    PickupEvent[]
  invoices        Invoice[]
  conversations   Conversation[]
  grades          Grade[]
}

model Class {
  id           String     @id @default(cuid())
  name         String
  monthlyFee   Float
  schoolYear   SchoolYear @relation(fields: [schoolYearId], references: [id])
  schoolYearId String
  createdAt    DateTime   @default(now())
  subjects     Subject[]
  teachers     Teacher[]
  Student      Student[]
  evaluations  Evaluation[]
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
}

model Document {
  id        String   @id @default(cuid())
  url       String
  fileName  String
  fileType  String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id])
  studentId String
}

model Subject {
  id        String    @id @default(cuid())
  name      String
  class     Class     @relation(fields: [classId], references: [id])
  classId   String
  createdAt DateTime  @default(now())
  teachers    Teacher[]
  evaluations Evaluation[]
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
}

model Teacher {
  id                String                    @id @default(cuid())
  userId            String?                   @unique
  user              User?                     @relation(fields: [userId], references: [id])
  subject           Subject?                  @relation(fields: [subjectId], references: [id])
  subjectId         String?
  class             Class?                    @relation(fields: [classId], references: [id])
  classId           String?
  Notification      Notification[]
  notificationsRead NotificationReadTeacher[]
  evaluations       Evaluation[]
  tenantId          String
  tenant            Tenant                    @relation(fields: [tenantId], references: [id])
}

model SchoolYear {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())

  classes  Class[]
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
}

model Notification {
  id             String                    @id @default(cuid())
  title          String
  message        String
  isGlobal       Boolean
  // Category drives badge color, icon, and parent-side filters.
  // Default GENERAL keeps existing rows valid post-migration.
  category       NotificationCategory      @default(GENERAL)
  studentId      String?
  student        Student?                  @relation(fields: [studentId], references: [id])
  teacherId      String?
  teacher        Teacher?                  @relation(fields: [teacherId], references: [id])
  tenantId       String?
  tenant         Tenant?                   @relation(fields: [tenantId], references: [id])
  createdAt      DateTime                  @default(now())
  readBy         NotificationRead[]
  readByTeachers NotificationReadTeacher[]

  @@index([tenantId, category, createdAt])
}

enum NotificationCategory {
  GENERAL
  ANNOUNCEMENT
  ACADEMIC
  ATTENDANCE
  BILLING
  EVENT
  HEALTH
  ADMIN
}

model NotificationRead {
  id             String       @id @default(uuid())
  notification   Notification @relation(fields: [notificationId], references: [id])
  notificationId String
  parent         User         @relation(fields: [parentId], references: [id])
  parentId       String
  readAt         DateTime?

  @@unique([notificationId, parentId])
}

model NotificationReadTeacher {
  id             String       @id @default(uuid())
  notification   Notification @relation(fields: [notificationId], references: [id])
  notificationId String
  teacher        Teacher      @relation(fields: [teacherId], references: [id])
  teacherId      String
  readAt         DateTime?

  @@unique([notificationId, teacherId])
}

model Tenant {
  id                   String                  @id @default(cuid())
  name                 String
  email                String?
  uniqueNumber         Int?                    @unique // ex: 123456
  stripeCustomerId     String?
  billingPlan          BillingPlan             @default(FREE_TRIAL)
  trialEndsAt          DateTime?
  createdAt            DateTime                @default(now())
  status               String?
  users                User[]
  students             Student[]
  classes              Class[]
  teachers             Teacher[]
  subjects             Subject[]
  years                SchoolYear[]
  phone                String?
  address              String?
  Notification         Notification[]
  schoolCode           String                  @unique
  InvitedParent        InvitedParent[]
  subscriptionStatus   String? // ex: "ACTIVE", "TRIAL", "EXPIRED"
  stripeSubscriptionId String?
  staff                Staff[]
  preRegistrations     PreRegistrationParent[]
  pickupAuthorizations PickupAuthorization[]
  pickupEvents         PickupEvent[]
  invoices             Invoice[]
  payments             Payment[]
  reminders            Reminder[]
  staffContracts       StaffContract[]
  staffHoursLogs       StaffHoursLog[]
  schoolEvents         SchoolEvent[]
  conversations        Conversation[]
  evaluations          Evaluation[]
}

model InvitedParent {
  id        String   @id @default(cuid())
  email     String
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  firstName String?
}

model Staff {
  id          String    @id @default(cuid())
  email       String    @unique
  firstName   String
  lastName    String
  phone       String
  roleLabel   String // ex: "Secrétaire", "Assistant administratif"
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now())
  validatedAt DateTime?
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  schoolCode  String?
  accepted    Boolean   @default(false)
  user        User?     @relation(fields: [userId], references: [id])
  userId      String?

  contracts      StaffContract[]
  hoursLogs      StaffHoursLog[]

  @@unique([email, tenantId])
}

model PreRegistrationParent {
  id        String                   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String
  address   String
  createdAt DateTime                 @default(now())
  status    PreRegistrationStatus    @default(PENDING)
  tenantId  String
  tenant    Tenant                   @relation(fields: [tenantId], references: [id])
  children  PreRegistrationChild[]
  documents PreRegistrationDocument?
}

model PreRegistrationDocument {
  id                  String                @id @default(cuid())
  motivationLetterUrl String?
  schoolResultsUrl    String?
  familyBookUrl       String?
  parentId            String                @unique
  parent              PreRegistrationParent @relation(fields: [parentId], references: [id])
}

model PreRegistrationChild {
  id            String                @id @default(cuid())
  firstName     String
  lastName      String
  gender        String
  birthDate     DateTime
  birthCity     String
  birthCountry  String
  currentSchool String
  desiredClass  String
  status        PreRegistrationStatus @default(PENDING)
  parent        PreRegistrationParent @relation(fields: [parentId], references: [id])
  parentId      String
  createdAt     DateTime              @default(now())
}

enum Gender {
  FILLE
  GARÇON
}

enum BillingPlan {
  FREE_TRIAL
  MONTHLY
  YEARLY
}

enum Role {
  PARENT
  TEACHER
  DIRECTOR
  SUPER_ADMIN
  STAFF
}

enum Civility {
  M
  Mme
  Mlle
}

enum PreRegistrationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model PickupAuthorization {
  id              String    @id @default(cuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  firstName       String
  lastName        String
  relationship    String?
  phone           String?
  notes           String?
  photoUrl        String?

  // null = permanent authorization. Non-null = expires at this datetime
  // (e.g. one-day "today only my friend Sarah picks up").
  expiresAt       DateTime?

  createdByUserId String
  createdBy       User      @relation("PickupAuthorizationCreatedBy", fields: [createdByUserId], references: [id])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  events          PickupEvent[]

  @@index([studentId])
  @@index([tenantId])
  @@index([expiresAt])
}

model PickupEvent {
  id              String    @id @default(cuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id])

  // "ENTRY" (drop-off) | "EXIT" (pickup)
  type            String
  occurredAt      DateTime  @default(now())

  // Selected authorization (preferred) — describes who actually picked up.
  authorizationId String?
  authorization   PickupAuthorization? @relation(fields: [authorizationId], references: [id])

  // Free-text fallback for ad-hoc / non-authorized entries (e.g. parent's
  // own drop-off; the school logs the parent's name even though there's no
  // formal authorization row for the parent themselves).
  pickupName      String?

  loggedByUserId  String
  loggedBy        User      @relation("PickupEventLoggedBy", fields: [loggedByUserId], references: [id])

  notes           String?

  @@index([studentId, occurredAt])
  @@index([tenantId, occurredAt])
}

model ProcessedStripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorEmail  String?
  actorRole   String?
  action      String
  targetType  String?
  targetId    String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorUserId])
  @@index([action])
}

model DailyJournal {
  id           String        @id @default(cuid())
  tenantId     String
  classId      String
  subjectId    String?
  teacherId    String
  date         DateTime
  classSummary String
  homework     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  readBy       JournalRead[]

  @@index([tenantId, classId, date])
  @@index([teacherId, date])
}

model JournalRead {
  id        String       @id @default(cuid())
  journal   DailyJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  journalId String
  parentId  String
  readAt    DateTime     @default(now())

  @@unique([journalId, parentId])
  @@index([parentId])
}

model Attendance {
  id                  String    @id @default(cuid())
  tenantId            String
  classId             String
  studentId           String
  student             Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date                DateTime
  status              String
  notes               String?
  markedByTeacherId   String
  markedAt            DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  justificationNotes  String?
  justificationDocId  String?
  justifiedByParentId String?
  justifiedAt         DateTime?

  @@unique([studentId, date])
  @@index([tenantId, classId, date])
  @@index([studentId, date])
}

// ---------------------------------------------------------------------------
// Finance — Invoices & Payments
// ---------------------------------------------------------------------------

model Invoice {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  studentId   String
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  number      String        // e.g. "INV-2026-001"
  amount      Float
  status      InvoiceStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  payments    Payment[]
  reminders   Reminder[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([studentId])
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

model Payment {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  invoiceId String
  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Float
  method    PaymentMethod
  reference String?       // bank ref, cheque number, etc.
  paidAt    DateTime      @default(now())
  notes     String?
  createdAt DateTime      @default(now())

  @@index([tenantId, paidAt])
  @@index([invoiceId])
}

enum PaymentMethod {
  BANK_TRANSFER
  CHEQUE
  CASH
  DIRECT_DEBIT
  OTHER
}

model Reminder {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sentAt    DateTime @default(now())
  channel   String   @default("EMAIL") // EMAIL, SMS
  notes     String?

  @@index([tenantId, sentAt])
  @@index([invoiceId])
}

// ---------------------------------------------------------------------------
// HR — Contracts & Staff Hours
// ---------------------------------------------------------------------------

model StaffContract {
  id          String             @id @default(cuid())
  tenantId    String
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  staffId     String
  staff       Staff              @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type        ContractType
  startDate   DateTime
  endDate     DateTime?
  hoursPerWeek Float?
  salary      Float?
  status      ContractStatus     @default(ACTIVE)
  notes       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([tenantId, status])
  @@index([staffId])
}

enum ContractType {
  CDI
  CDD
  STAGE
  FREELANCE
  OTHER
}

enum ContractStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  TERMINATED
}

model StaffHoursLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date      DateTime
  hours     Float
  overtime  Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())

  @@unique([staffId, date])
  @@index([tenantId, date])
  @@index([staffId, date])
}

// ---------------------------------------------------------------------------
// Planning — Events
// ---------------------------------------------------------------------------

model SchoolEvent {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  location    String?
  type        String   @default("GENERAL") // GENERAL, MEETING, HOLIDAY, EXAM, TRIP
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, startDate])
}

// ---------------------------------------------------------------------------
// Messaging — Conversations & Messages
// ---------------------------------------------------------------------------

model Conversation {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  subject     String
  studentId   String?
  student     Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
  participants ConversationParticipant[]

  @@index([tenantId, updatedAt])
  @@index([studentId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  body           String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// ---------------------------------------------------------------------------
// Grades & Evaluations
// ---------------------------------------------------------------------------

model Evaluation {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  classId     String
  class       Class    @relation(fields: [classId], references: [id])
  subjectId   String?
  subject     Subject? @relation(fields: [subjectId], references: [id])
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  title       String
  description String?
  date        DateTime
  maxScore    Float    @default(20)
  coefficient Float   @default(1)
  type        String   @default("EXAM") // EXAM, QUIZ, HOMEWORK, ORAL, PROJECT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  grades      Grade[]

  @@index([tenantId, classId, date])
  @@index([teacherId, date])
}

model Grade {
  id           String     @id @default(cuid())
  evaluationId String
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score        Float?
  absent       Boolean    @default(false)
  comment      String?
  createdAt    DateTime   @default(now())

  @@unique([evaluationId, studentId])
  @@index([studentId])
}
